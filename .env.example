# Copy to .env and fill in your values
# (never commit .env to git)

# LLM endpoint
API_BASE_URL=https://router.huggingface.co/v1

# Model to use for inference
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Your HuggingFace token
HF_TOKEN=

# Optional: local Docker image name (if testing with Docker)
# LOCAL_IMAGE_NAME=adem-env:latest

# Optional: connect to existing server (skips Docker startup)
# ADEM_SERVER_URL=http://localhost:8000